{
  "openapi": "3.0.0",
  "info": {
    "title": "CarPlex OAS",
    "contact": {
      "name": "API",
      "email": "a@b.com"
    },
    "description": "OAS description for API responses in CarPlex application",
    "version": "0.1.0"
  },
  "servers": [
    {
      "url": "http://localhost:8000"
    }
  ],
  "paths": {
    "/api/auth": {
      "description": "Authorization endpoint",
      "post": {
        "operationId": "login",
        "summary": "Login with an existing user",
        "description": "Login an already registered user, gives admin rights",
        "tags": [
          "Authentication"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Login"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successfull login",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AccessToken"
                }
              }
            }
          },
          "401": {
            "description": "Login failed - invalid username or password",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "422": {
            "description": "Invalid input data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/movies": {
      "get": {
        "operationId": "getMovies",
        "description": "Retrieves stored movies",
        "summary": "Search movies",
        "tags": [
          "Movies"
        ],
        "parameters": [
          {
            "in": "query",
            "name": "page",
            "schema": {
              "type": "number"
            },
            "description": "Pagination's page to retrieve items"
          }
        ],
        "responses": {
          "200": {
            "description": "Pagination result of movies",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MoviesList"
                }
              }
            }
          },
          "422": {
            "description": "Invalid search parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ValidationError"
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "addMovie",
        "description": "Add a new movie to the list - the name & release date should be unique",
        "summary": "Add movie",
        "tags": [
          "Movies"
        ],
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateMovie"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Movie added successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Movie"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "409": {
            "description": "The movie with the title & release date already exists in the database",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "422": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/movies/{movieId}": {
      "get": {
        "operationId": "getMovie",
        "description": "Returns the selected movie details",
        "summary": "Get movie",
        "tags": [
          "Movies"
        ],
        "parameters": [
          {
            "in": "path",
            "name": "movieId",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Movie details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Movie"
                }
              }
            }
          },
          "404": {
            "description": "Cannot find movie with the defined movieId",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      },
      "put": {
        "description": "Update movie details",
        "operationId": "updateMovie",
        "summary": "Update movie",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "tags": [
          "Movies"
        ],
        "parameters": [
          {
            "in": "path",
            "name": "movieId",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateMovie"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Movie updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Movie"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Cannot find movie with the defined movieId",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "409": {
            "description": "The movie with the title & release date already exists in the database",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "422": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ValidationError"
                }
              }
            }
          }
        }
      },
      "delete": {
        "description": "Removes a movie together with connected screenings",
        "operationId": "deleteMovie",
        "summary": "Delete movie",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "tags": [
          "Movies"
        ],
        "parameters": [
          {
            "in": "path",
            "name": "movieId",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Movie removed"
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Cannot find movie with the defined movieId",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/api/screenings": {
      "get": {
        "description": "Get all available screenings",
        "operationId": "getScreenings",
        "summary": "Search screenings",
        "tags": [
          "Screenings"
        ],
        "parameters": [
          {
            "in": "query",
            "name": "movie",
            "schema": {
              "type": "integer",
              "minimum": 0
            }
          },
          {
            "in": "query",
            "name": "period_start",
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "in": "query",
            "name": "period_end",
            "schema": {
              "type": "string",
              "format": "date"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Search items",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ScreeningsList"
                }
              }
            }
          },
          "422": {
            "description": "Invalid input fields",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ValidationError"
                }
              }
            }
          }
        }
      },
      "post": {
        "description": "Add a new screening to the existing one. The new screening should not collide with others, so the start and end time must be choosen carefully",
        "operationId": "addScreening",
        "summary": "Add screening",
        "tags": [
          "Screenings"
        ],
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateScreening"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Movie created succesfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Screening"
                }
              }
            }
          },
          "401": {
            "description": "Login failed - invalid username or password",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "409": {
            "description": "The selected time collides with other screening, select different dates",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "422": {
            "description": "Invalid input data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/screenings/{screeningId}": {
      "get": {
        "description": "Get screening data",
        "operationId": "getScreening",
        "summary": "Get screening",
        "tags": [
          "Screenings"
        ],
        "parameters": [
          {
            "in": "path",
            "name": "screeningId",
            "required": true,
            "schema": {
              "type": "integer",
              "minimum": 0
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Search items",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Screening"
                }
              }
            }
          },
          "404": {
            "description": "Screening not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      },
      "put": {
        "description": "Update existing screening. The new info should not collide with other screenings, so the start and end time must be choosen carefully",
        "operationId": "updateScreening",
        "summary": "Update screening",
        "tags": [
          "Screenings"
        ],
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "in": "path",
            "name": "screeningId",
            "required": true,
            "schema": {
              "type": "integer",
              "minimum": 0
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateScreening"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Movie created succesfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Screening"
                }
              }
            }
          },
          "401": {
            "description": "Login failed - invalid username or password",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "409": {
            "description": "The selected time collides with other screening, select different dates",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "422": {
            "description": "Invalid input data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ValidationError"
                }
              }
            }
          }
        }
      },
      "delete": {
        "description": "Removes an existing screening",
        "operationId": "deleteScreening",
        "summary": "Delete screening",
        "parameters": [
          {
            "in": "path",
            "name": "screeningId",
            "required": true,
            "schema": {
              "type": "integer",
              "minimum": 0
            }
          }
        ],
        "tags": [
          "Screenings"
        ],
        "responses": {
          "204": {
            "description": "Screening removed"
          },
          "401": {
            "description": "Login failed - invalid username or password",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Screening not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/api/user/current": {
      "get": {
        "description": "Returns the user data of a logged in user",
        "operationId": "getCurrentUserInfo",
        "summary": "Get current user",
        "tags": [
          "Authentication"
        ],
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Current users data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/User"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "required": [
          "message"
        ],
        "properties": {
          "message": {
            "type": "string",
            "description": "Describes the issue"
          }
        }
      },
      "ValidationError": {
        "type": "object",
        "required": [
          "message",
          "errors"
        ],
        "properties": {
          "message": {
            "type": "string",
            "description": "Describes the issue"
          },
          "errors": {
            "type": "object",
            "description": "List of invalid elements",
            "additionalProperties": {
              "type": "array",
              "items": {
                "type": "string",
                "description": "Cause of the field was invalid"
              }
            }
          }
        }
      },
      "Login": {
        "type": "object",
        "required": [
          "username",
          "password"
        ],
        "properties": {
          "username": {
            "type": "string",
            "description": "Email address of an existing user"
          },
          "password": {
            "type": "string",
            "description": "Password of an existing user"
          }
        }
      },
      "AccessToken": {
        "type": "object",
        "required": [
          "accessToken"
        ],
        "properties": {
          "accessToken": {
            "type": "string",
            "description": "Provides access to endpoints which requires authorization. Use as a Bearer token in Authorization header."
          }
        }
      },
      "User": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "minimum": 0
          },
          "name": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "emailAddress"
          }
        }
      },
      "PaginatedResponse": {
        "type": "object",
        "required": [
          "current_page",
          "from",
          "to",
          "per_page",
          "total"
        ],
        "properties": {
          "current_page": {
            "type": "integer"
          },
          "from": {
            "type": "integer"
          },
          "to": {
            "type": "integer"
          },
          "per_page": {
            "type": "integer"
          },
          "total": {
            "type": "integer"
          },
          "last_page": {
            "type": "integer"
          },
          "last_page_url": {
            "type": "string",
            "format": "url"
          },
          "next_page_url": {
            "type": "string",
            "format": "url"
          },
          "prev_page_url": {
            "type": "string",
            "format": "url"
          },
          "path": {
            "type": "string",
            "format": "url"
          },
          "first_page_url": {
            "type": "string",
            "format": "url"
          }
        }
      },
      "Movie": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "title": {
            "type": "string"
          },
          "tagline": {
            "type": "string"
          },
          "release_date": {
            "type": "string",
            "format": "date"
          },
          "poster_path": {
            "type": "string",
            "format": "url"
          },
          "overview": {
            "type": "string"
          },
          "runtime": {
            "type": "integer"
          },
          "certification": {
            "$ref": "#/components/schemas/Certification"
          },
          "created_at": {
            "type": "string",
            "format": "datetime"
          },
          "updated_at": {
            "type": "string",
            "format": "datetime"
          }
        },
        "required": [
          "id",
          "title",
          "release_date",
          "poster_path",
          "overview",
          "created_at",
          "updated_at"
        ]
      },
      "CreateMovie": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "tagline": {
            "type": "string"
          },
          "release_date": {
            "type": "string",
            "format": "date"
          },
          "poster_path": {
            "type": "string",
            "format": "url"
          },
          "overview": {
            "type": "string"
          },
          "runtime": {
            "type": "integer"
          },
          "certification": {
            "$ref": "#/components/schemas/Certification"
          }
        },
        "required": [
          "title",
          "release_date",
          "poster_path",
          "overview"
        ]
      },
      "Certification": {
        "description": "Hungary specific age rating",
        "type": "string",
        "enum": [
          "KN",
          "6",
          "12",
          "16",
          "18",
          "X"
        ]
      },
      "Screening": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "movie_id": {
            "type": "integer"
          },
          "movie": {
            "$ref": "#/components/schemas/Movie"
          },
          "start_time": {
            "type": "string",
            "format": "datetime"
          },
          "end_time": {
            "type": "string",
            "format": "datetime"
          },
          "capacity": {
            "type": "integer",
            "minimum": 1
          },
          "created_at": {
            "type": "string",
            "format": "datetime"
          },
          "updated_at": {
            "type": "string",
            "format": "datetime"
          }
        }
      },
      "CreateScreening": {
        "type": "object",
        "required": [
          "movie_id",
          "start_time",
          "end_time",
          "capaciy"
        ],
        "properties": {
          "movie_id": {
            "type": "integer"
          },
          "start_time": {
            "type": "string",
            "format": "datetime"
          },
          "end_time": {
            "type": "string",
            "format": "datetime"
          },
          "capacity": {
            "type": "integer",
            "minimum": 1
          }
        }
      },
      "MoviesList": {
        "allOf": [
          {
            "$ref": "#/components/schemas/PaginatedResponse"
          },
          {
            "type": "object",
            "required": [
              "data"
            ],
            "properties": {
              "data": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/Movie"
                },
                "maxItems": 6
              }
            }
          }
        ]
      },
      "ScreeningsList": {
        "allOf": [
          {
            "$ref": "#/components/schemas/PaginatedResponse"
          },
          {
            "type": "object",
            "required": [
              "data"
            ],
            "properties": {
              "data": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/Screening"
                },
                "maxItems": 10
              }
            }
          }
        ]
      }
    },
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    }
  },
  "tags": [
    {
      "name": "Authentication",
      "description": "Endpoints related to authentication and authorization"
    },
    {
      "name": "Movies",
      "description": "Endpoints related to handling Movie objects"
    },
    {
      "name": "Screenings",
      "description": "Endpoints related to handle CRUD operation on Screening objects"
    }
  ]
}